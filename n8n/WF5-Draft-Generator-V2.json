      "name": "Call App Draft Agent",
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst task     = $('Extract Task Fields').first().json;\n\n// The app returns { ok: true, draft_id: 'uuid' } on success\n// or { ok: false, error: 'message' } on failure.\n// If the HTTP call itself failed, response may be an error object.\nconst ok = response.ok === true;\nconst errorMsg = !ok\n  ? (response.error || ('Unexpected response: ' + JSON.stringify(response).slice(0, 200)))\n  : null;\n\nreturn [{\n  json: {\n    task_id:       task.task_id,\n    ok,\n    draft_id:      response.draft_id || null,\n    error_message: errorMsg\n  }\n}];"
      },
