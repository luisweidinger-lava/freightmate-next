      "parameters": {
        "jsCode": "// Extract the fields we need from the draft_tasks row.\n// This runs once per task in the batch loop.\nconst task = $input.first().json;\n\nreturn [{\n  json: {\n    task_id:      task.id,\n    case_id:      task.case_id,\n    channel_type: task.channel_type || 'client',\n    draft_type:   task.draft_type   || 'generic'\n  }\n}];"
